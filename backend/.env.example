# Configuration de production - Copiez ce fichier vers .env et remplissez les valeurs

# Django
SECRET_KEY=your-super-secret-key-here-change-this-in-production
DEBUG=False

# Base de données PostgreSQL
DB_NAME=resume_plus_db
DB_USER=resume_user
DB_PASSWORD=your_secure_database_password
DB_HOST=localhost
DB_PORT=5432

# Email (optionnel)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@resumecours.gestionhospitaliare.site

# Redis (pour Celery - optionnel)
REDIS_URL=redis://localhost:6379/0

# Domaine de production
DOMAIN=resumecours.gestionhospitaliare.site