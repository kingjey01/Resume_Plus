import 'dart:io';
import 'dart:async';
import 'package:dio/dio.dart';
import 'package:flutter/foundation.dart';
import 'package:resume_plus/models/summary.dart' as model;
import 'package:resume_plus/services/snackbar_service.dart';
import 'package:resume_plus/services/storage_service.dart';
import '../models/universite.dart';
import '../models/promotion.dart';
import '../models/filiere.dart';
import 'package:resume_plus/models/universite_filiere.dart';
import 'package:resume_plus/models/filiere_promotion.dart';

class ApiService {
  final Dio _dio;
  final StorageService _storageService;
  // Configuration pour production avec backend déployé en ligne
  // Backend déployé sur: resumecours.gestionhospitaliare.site
  
  static const String productionUrl = 'https://resumecours.gestionhospitaliare.site/api';
  static const String developmentUrl = 'http://192.168.1.110:8000/api';
  
  // Mode production : true pour utiliser le backend en ligne, false pour développement local
  static const bool isProduction = false;
  
  static const String baseUrl = isProduction ? productionUrl : developmentUrl;
  
  // Verrou pour éviter les rafraîchissements multiples en parallèle
  final _refreshLock = Lock();
  bool _isRefreshing = false;
  
  // Cache pour les données fréquemment utilisées
  List<Universite>? _cachedUniversites;
  Map<int, List<Filiere>> _cachedFilieresByUniversite = {};
  Map<int, List<Promotion>> _cachedPromotionsByFiliere = {};

  ApiService({Dio? dio, StorageService? storageService})
      : _dio = dio ?? Dio(BaseOptions(baseUrl: baseUrl)),
        _storageService = storageService ?? StorageService() {

    _dio.interceptors.add(InterceptorsWrapper(
      onRequest: _onRequest,
      onError: _onError,
      onResponse: _onResponse,
    ));
  }

  // Gestionnaire de requête pour ajouter le token d'accès
  Future<void> _onRequest(RequestOptions options, RequestInterceptorHandler handler) async {
    // Récupérer le token seulement pour les endpoints qui en ont besoin
    final publicEndpoints = [
      '/auth/login/',
      '/auth/register/',
      '/auth/password/reset/',
      '/auth/token/refresh/',
      '/courses/universites/',
      '/courses/promotions/',
      '/courses/filieres/',
    ];
    
    final isAuthRequest = options.path.contains('/auth/');
    final isPublicEndpoint = publicEndpoints.any((endpoint) => options.path.endsWith(endpoint));
    
    if (!isPublicEndpoint || isAuthRequest) {
      final token = await _storageService.accessToken;
      if (token != null) {
        options.headers['Authorization'] = 'Bearer $token';
      }
    }
    
    return handler.next(options);
  }

  // Gestionnaire de réponse pour traiter les réponses
  void _onResponse(Response response, ResponseInterceptorHandler handler) {
    // Vous pouvez ajouter ici un traitement global des réponses si nécessaire
    return handler.next(response);
  }

  // Gestionnaire d'erreurs pour gérer les tokens expirés
  Future<void> _onError(DioException err, ErrorInterceptorHandler handler) async {
    final response = err.response;
    
    // Si l'erreur est 401 et que ce n'est pas une tentative de rafraîchissement
    if (response?.statusCode == 401 && 
        !err.requestOptions.path.endsWith('/auth/token/refresh/') &&
        !err.requestOptions.path.endsWith('/auth/login/')) {
      
      try {
        // Tenter de rafraîchir le token
        final newToken = await refreshToken();
        
        if (newToken != null) {
          // Mettre à jour le token dans l'en-tête de la requête originale
          err.requestOptions.headers['Authorization'] = 'Bearer $newToken';
          
          // Renvoyer la requête avec le nouveau token
          final opts = Options(
            method: err.requestOptions.method,
            headers: err.requestOptions.headers,
          );
          
          final newResponse = await _dio.request<dynamic>(
            err.requestOptions.path,
            options: opts,
            data: err.requestOptions.data,
            queryParameters: err.requestOptions.queryParameters,
          );
          
          return handler.resolve(newResponse);
        }
      } catch (e) {
        // En cas d'échec du rafraîchissement, déconnecter l'utilisateur
        if (e is DioException && e.response?.statusCode == 401) {
          await _storageService.deleteTokens();
          // Ici, vous pourriez rediriger vers l'écran de connexion
          // Par exemple en utilisant un gestionnaire d'état global ou un navigateur
        }
        return handler.next(err);
      }
    }
    
    // Gestion des autres erreurs
    String errorMessage = 'Une erreur est survenue';
    
    if (response?.statusCode == 400) {
      if (err.requestOptions.path.endsWith('/auth/login/')) {
        errorMessage = 'Identifiants incorrects';
      } else if (response?.data is Map) {
        // Essayer d'extraire un message d'erreur de la réponse
        final data = response!.data as Map<String, dynamic>;
        errorMessage = data['detail'] ?? data['message'] ?? data.toString();
      }
    } else if (response?.statusCode == 404) {
      errorMessage = 'Ressource non trouvée';
    } else if (response?.statusCode == 500) {
      errorMessage = 'Erreur serveur';
    } else if (err.type == DioExceptionType.connectionTimeout ||
               err.type == DioExceptionType.receiveTimeout ||
               err.type == DioExceptionType.sendTimeout) {
      errorMessage = 'Délai de connexion dépassé';
    } else if (err.type == DioExceptionType.connectionError) {
      errorMessage = 'Erreur de connexion';
    }
    
    // Afficher le message d'erreur à l'utilisateur
    SnackbarService.show(errorMessage, isError: true);
    
    return handler.next(err);
  }
  }

  // ============================================
  // Gestion des universités, filières et promotions
  // ============================================

  /// Récupère la liste des universités
  Future<List<Universite>> getUniversites({bool forceRefresh = false}) async {
    try {
      if (_cachedUniversites != null && !forceRefresh) {
        return _cachedUniversites!;
      }
      
      final response = await _dio.get('/universites/');
      if (response.statusCode == 200) {
        _cachedUniversites = (response.data as List)
            .map((json) => Universite.fromJson(json))
            .toList();
        return _cachedUniversites!;
      }
      return [];
    } on DioException catch (e) {
      SnackbarService.show('Erreur lors du chargement des universités', isError: true);
      rethrow;
    }
  }

  /// Récupère les filières d'une université
  Future<List<Filiere>> getFilieresByUniversite(int universiteId, {bool forceRefresh = false}) async {
    try {
      if (_cachedFilieresByUniversite[universiteId] != null && !forceRefresh) {
        return _cachedFilieresByUniversite[universiteId]!;
      }
      
      final response = await _dio.get('/universites/$universiteId/filieres/');
      if (response.statusCode == 200) {
        final filieres = (response.data as List)
            .map((json) => Filiere.fromJson(json))
            .toList();
        _cachedFilieresByUniversite[universiteId] = filieres;
        return filieres;
      }
      return [];
    } on DioException catch (e) {
      SnackbarService.show('Erreur lors du chargement des filières', isError: true);
      rethrow;
    }
  }

  /// Récupère les promotions d'une filière
  Future<List<Promotion>> getPromotionsByFiliere(int filiereId, {bool forceRefresh = false}) async {
    try {
      if (_cachedPromotionsByFiliere[filiereId] != null && !forceRefresh) {
        return _cachedPromotionsByFiliere[filiereId]!;
      }
      
      final response = await _dio.get('/filieres/$filiereId/promotions/');
      if (response.statusCode == 200) {
        final promotions = (response.data as List)
            .map((json) => Promotion.fromJson(json))
            .toList();
        _cachedPromotionsByFiliere[filiereId] = promotions;
        return promotions;
      }
      return [];
    } on DioException catch (e) {
      SnackbarService.show('Erreur lors du chargement des promotions', isError: true);
      rethrow;
    }
  }

  /// Met à jour le cache pour une université et ses filières
  Future<void> refreshUniversiteData(int universiteId) async {
    await getUniversites(forceRefresh: true);
    await getFilieresByUniversite(universiteId, forceRefresh: true);
  }

  /// Met à jour le cache pour une filière et ses promotions
  Future<void> refreshFiliereData(int filiereId) async {
    await getPromotionsByFiliere(filiereId, forceRefresh: true);
  }

  // ============================================
  // Authentification et utilisateur
  // ============================================
  
  /// Connecte l'utilisateur avec un nom d'utilisateur et un mot de passe
  /// Retourne un Map contenant les tokens d'accès et de rafraîchissement
  Future<Map<String, dynamic>> login(String username, String password) async {
    try {
      final response = await _dio.post('/auth/login/', data: {
        'username': username,
        'password': password,
      });

      if (response.statusCode == 200) {
        final data = response.data as Map<String, dynamic>;
        
        // Vérifier que nous avons bien les tokens nécessaires
        if (data['access'] == null || data['refresh'] == null) {
          throw Exception('Réponse de connexion invalide: tokens manquants');
        }
        
        // Stocker les tokens
        await _storageService.writeTokens(
          accessToken: data['access'],
          refreshToken: data['refresh'],
        );
        
        // Retourner les données de l'utilisateur si disponibles
        return {
          'tokens': {
            'access': data['access'],
            'refresh': data['refresh'],
          },
          'user': data['user'] // Si le backend renvoie également les infos utilisateur
        };
      } else {
        throw Exception('Échec de la connexion: ${response.statusCode}');
      }
    } on DioException catch (e) {
      // L'intercepteur onError gère déjà l'affichage du message d'erreur
      rethrow;
    }
  }
  
  /// Rafraîchit le token d'accès en utilisant le token de rafraîchissement
  /// Retourne le nouveau token d'accès ou null en cas d'échec
  Future<String?> refreshToken() async {
    // Éviter les appels multiples en parallèle
    if (_isRefreshing) {
      await _refreshLock.lock();
      _refreshLock.unlock();
      return await _storageService.accessToken;
    }
    
    try {
      _isRefreshing = true;
      _refreshLock.lock();
      
      final refreshToken = await _storageService.refreshToken;
      if (refreshToken == null) {
        return null;
      }
      
      final response = await _dio.post(
        '/auth/token/refresh/',
        data: {'refresh': refreshToken},
      );
      
      if (response.statusCode == 200 && response.data['access'] != null) {
        final newAccessToken = response.data['access'] as String;
        final newRefreshToken = response.data['refresh'] as String? ?? refreshToken;
        
        // Mettre à jour les tokens stockés
        await _storageService.writeTokens(
          accessToken: newAccessToken,
          refreshToken: newRefreshToken,
        );
        
        return newAccessToken;
      }
      
      return null;
    } on DioException catch (e) {
      // En cas d'erreur 401, le token de rafraîchissement est invalide ou expiré
      if (e.response?.statusCode == 401) {
        await _storageService.deleteTokens();
        // Ici, vous pourriez rediriger vers l'écran de connexion
      }
      return null;
    } catch (e) {
      return null;
    } finally {
      _isRefreshing = false;
      _refreshLock.unlock();
    }
  }
  
  /// Déconnecte l'utilisateur et supprime les tokens
  Future<void> logout() async {
    try {
      final refreshToken = await _storageService.refreshToken;
      if (refreshToken != null) {
        await _dio.post(
          '/auth/logout/',
          data: {'refresh': refreshToken},
        );
      }
    } catch (e) {
      // Même en cas d'erreur, on supprime les tokens localement
    } finally {
      await _storageService.deleteTokens();
    }
  }
  
  /// Récupère le profil de l'utilisateur connecté
  Future<Map<String, dynamic>> getUserProfile() async {
    try {
      final response = await _dio.get('/auth/user/');
      if (response.statusCode == 200) {
        return response.data as Map<String, dynamic>;
      }
      throw Exception('Impossible de récupérer le profil utilisateur');
    } on DioException catch (e) {
      rethrow;
    }
  }

  Future<List<model.Summary>> getSummaries({String? search}) async {
    try {
      final queryParams = <String, dynamic>{};
      if (search != null && search.isNotEmpty) {
        queryParams['search'] = search;
      }
      
      final response = await _dio.get('/summaries/', queryParameters: queryParams);
      if (response.statusCode == 200) {
        // Vérifier si la réponse est une liste ou un objet paginé
        dynamic data = response.data;
        List<dynamic> summariesList;
        
        if (data is List) {
          // Réponse directe sous forme de liste
          summariesList = data;
        } else if (data is Map && data.containsKey('results')) {
          // Réponse paginée Django REST Framework
          summariesList = data['results'] as List;
        } else {
          // Cas d'erreur - structure inattendue
          print('Structure de réponse inattendue: ${data.runtimeType}');
          print('Données: $data');
          throw Exception('Structure de réponse API inattendue');
        }
        
        final summaries = summariesList
            .map((summary) => model.Summary.fromJson(summary))
            .toList();
        return summaries;
      } else {
        throw Exception('Failed to load summaries');
      }
    } on DioException catch (e) {
      // Gestion d'erreurs plus spécifique pour les résumés
      if (e.type == DioExceptionType.connectionTimeout || 
          e.type == DioExceptionType.receiveTimeout) {
        throw Exception('Délai d\'attente dépassé. Vérifiez votre connexion.');
      } else if (e.type == DioExceptionType.connectionError) {
        throw Exception('Erreur de connexion. Vérifiez votre connexion internet.');
      }
      rethrow;
    }
  }

  Future<Map<String, dynamic>> getUserProfile() async {
    try {
      final response = await _dio.get('/auth/profile/');
      if (response.statusCode == 200) {
        return response.data;
      } else {
        throw Exception('Failed to load user profile');
      }
    } on DioException {
      rethrow;
    }
  }

  Future<void> logout() async {
    try {
      await _dio.post('/auth/logout/');
      await _storageService.deleteToken();
    } on DioException {
      // Même en cas d'erreur serveur, on supprime le token local
      await _storageService.deleteToken();
      rethrow;
    }
  }

