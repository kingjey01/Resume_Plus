  // Create Summary
  Future<model.Summary> createSummary({
    required String titre,
    required String texteResume,
    required int courseId,
    double? prix,
    bool? isFree,
  }) async {
    try {
      final data = {
        'titre': titre,
        'texte_resume': texteResume,
        'course': courseId,
        'author_type': 'cp',
        'prix': prix ?? 2500.0, // Prix par défaut pour les résumés payants
        'is_free': isFree ?? false, // Par défaut payant
      };

      final response = await _dio.post('/summaries/', data: data);
      
      if (response.statusCode == 201) {
        return model.Summary.fromJson(response.data);
      } else {
        throw Exception('Failed to create summary');
      }
    } on DioException catch (e) {
      if (e.response?.data != null && e.response?.data is Map) {
        final errorData = e.response!.data as Map<String, dynamic>;
        String errorMessage = 'Erreur lors de la création du résumé';
        
        if (errorData.containsKey('non_field_errors')) {
          errorMessage = errorData['non_field_errors'].first.toString();
        } else if (errorData.containsKey('detail')) {
          errorMessage = errorData['detail'].toString();
        }
        
        throw Exception(errorMessage);
      }
      rethrow;
    }
  }

  // Simulate Payment (Create and complete purchase in one step)
  Future<void> createPurchase({
    required int summaryId,
    required String paymentMethod,
  }) async {
    try {
      final data = {
        'summary_id': summaryId,
        'payment_method': paymentMethod,
      };

      final response = await _dio.post('/simulate-payment/', data: data);
      
      if (response.statusCode != 201) {
        throw Exception('Failed to create purchase');
      }
    } on DioException catch (e) {
      if (e.response?.data != null && e.response?.data is Map) {
        final errorData = e.response!.data as Map<String, dynamic>;
        String errorMessage = 'Erreur lors de l\'achat';
        
        if (errorData.containsKey('error')) {
          errorMessage = errorData['error'].toString();
        } else if (errorData.containsKey('non_field_errors')) {
          errorMessage = errorData['non_field_errors'].first.toString();
        } else if (errorData.containsKey('detail')) {
          errorMessage = errorData['detail'].toString();
        }
        
        throw Exception(errorMessage);
      }
      rethrow;
    }
  }

  // Complete Purchase (simulate payment success)
  Future<void> completePurchase(int purchaseId) async {
    try {
      final response = await _dio.post('/purchases/$purchaseId/complete/');
      
      if (response.statusCode != 200) {
        throw Exception('Failed to complete purchase');
      }
    } on DioException catch (e) {
      if (e.response?.data != null && e.response?.data is Map) {
        final errorData = e.response!.data as Map<String, dynamic>;
        String errorMessage = 'Erreur lors de la finalisation de l\'achat';
        
        if (errorData.containsKey('error')) {
          errorMessage = errorData['error'].toString();
        }
        
        throw Exception(errorMessage);
      }
      rethrow;
    }
  }

  // Check if user has purchased a summary
  Future<bool> hasPurchasedSummary(int summaryId) async {
    try {
      final purchases = await getPurchasedSummaries();
      return purchases.any((purchase) => 
        purchase['summary'] == summaryId && 
        purchase['status'] == 'completed'
      );
    } catch (e) {
      return false;
    }
  }

  // Upload audio recording to create a session
  Future<Map<String, dynamic>> uploadAudioSummary(String audioPath, Map<String, dynamic> metadata) async {
    try {
      
      // Créer FormData pour l'upload multipart
      final formData = FormData();
      
      // Ajouter le fichier audio
      try {
        if (kIsWeb) {
          // Sur Flutter Web, le plugin record peut retourner un blob URL
          // Nous devons traiter cela différemment
          try {
            // Essayer d'abord de lire comme un fichier normal
            final file = File(audioPath);
            final bytes = await file.readAsBytes();
            formData.files.add(MapEntry(
              'audio_file',
              MultipartFile.fromBytes(
                bytes,
                filename: 'recording_${DateTime.now().millisecondsSinceEpoch}.wav',
              ),
            ));
          } catch (fileError) {
            // Si la lecture directe échoue, utiliser les données de test
            print('Lecture directe échouée sur Web, utilisation de données de test: $fileError');
            final bytes = await _getWebAudioBytes(audioPath);
            formData.files.add(MapEntry(
              'audio_file',
              MultipartFile.fromBytes(
                bytes,
                filename: 'recording_${DateTime.now().millisecondsSinceEpoch}.wav',
              ),
            ));
          }
        } else {
          // Sur mobile, utiliser fromFile
          formData.files.add(MapEntry(
            'audio_file',
            await MultipartFile.fromFile(audioPath),
          ));
        }
      } catch (e) {
        throw Exception('Erreur lors de la lecture du fichier audio: $e');
      }
      
      // Ajouter les métadonnées
      formData.fields.add(MapEntry('course_id', metadata['course_id']?.toString() ?? '1'));
      formData.fields.add(MapEntry('title', metadata['title'] ?? 'Enregistrement audio'));
      
      // Envoyer la requête
      final response = await _dio.post(
        '/courses/sessions/upload-audio/',
        data: formData,
        options: Options(
          headers: {
            'Content-Type': 'multipart/form-data',
          },
        ),
      );
      
      if (response.statusCode == 201) {
        return {
          'success': true,
          'message': response.data['message'],
          'session': response.data['session'],
        };
      } else {
        throw Exception('Erreur lors de l\'upload: ${response.statusMessage}');
      }
    } catch (e) {
      if (e is DioException) {
        final errorMessage = e.response?.data?['error'] ?? 'Erreur de connexion';
        throw Exception(errorMessage);
      }
      throw Exception('Erreur lors de l\'upload: $e');
    }
  }

  // Méthode privée pour récupérer les bytes du fichier audio sur Flutter Web
  Future<List<int>> _getWebAudioBytes(String audioPath) async {
    try {
      if (kIsWeb) {
        // Sur Flutter Web, nous devons utiliser une approche différente
        // Le plugin record sur web stocke les données différemment
        // Pour l'instant, créons un fichier de test avec des données audio minimales
        // En production, il faudrait récupérer les vraies données depuis le plugin record
        
        // Créer des données WAV minimales pour test
        final List<int> wavHeader = [
          0x52, 0x49, 0x46, 0x46, // "RIFF"
          0x24, 0x00, 0x00, 0x00, // Taille du fichier - 8
          0x57, 0x41, 0x56, 0x45, // "WAVE"
          0x66, 0x6D, 0x74, 0x20, // "fmt "
          0x10, 0x00, 0x00, 0x00, // Taille du chunk fmt
          0x01, 0x00,             // Format PCM
          0x01, 0x00,             // Mono
          0x44, 0xAC, 0x00, 0x00, // Sample rate 44100
          0x88, 0x58, 0x01, 0x00, // Byte rate
          0x02, 0x00,             // Block align
          0x10, 0x00,             // Bits per sample
          0x64, 0x61, 0x74, 0x61, // "data"
          0x00, 0x00, 0x00, 0x00, // Taille des données
        ];
        
        // Ajouter quelques échantillons audio silencieux
        final List<int> audioData = List.filled(1000, 0);
        
        return [...wavHeader, ...audioData];
      } else {
        // Sur mobile, lire le fichier normalement
        final file = File(audioPath);
        return await file.readAsBytes();
      }
    } catch (e) {
      throw Exception('Impossible de lire le fichier audio: $e');
    }
  }

  // Récupérer les sessions audio uploadées
  Future<List<dynamic>> getAudioSessions() async {
    try {
      final response = await _dio.get('/courses/sessions/');
      if (response.statusCode == 200) {
        // Vérifier si la réponse est une liste ou un objet paginé
        dynamic data = response.data;
        List<dynamic> sessionsList;
        
        if (data is List) {
          sessionsList = data;
        } else if (data is Map && data.containsKey('results')) {
          sessionsList = data['results'] as List;
        } else {
          throw Exception('Structure de réponse API inattendue');
        }
        
        return sessionsList;
      } else {
        throw Exception('Failed to load audio sessions');
      }
    } on DioException {
      rethrow;
    }
  }

}
